export component HorizontalDivider {
    in property <brush> color: #ccc;
    in property <length> thickness: 1px;
    in property <length> width_size: 100px;

    width: root.width_size;
    height: root.thickness;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: root.color;
    }
}